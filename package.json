{
  "name": "seomation-extension",
  "version": "1.1.0",
  "description": "SEOmation browser extension for SEO auditing, page comparison, email extraction, and PDF export.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite build --watch --config vite.config.mjs",
    "build": "vite build --config vite.config.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
